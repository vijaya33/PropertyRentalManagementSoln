@page "/landlords"
@using Microsoft.EntityFrameworkCore
@using PropertyRentalManagement.Core.Entities
@inject PropertyRentalManagement.Infrastructure.Data.RentalDbContext Db
@inject NavigationManager Nav

@attribute [Authorize]


<h3>Landlords</h3>

<a class="btn btn-primary mb-3" href="/landlords/create">Add New Landlord</a>

@if (!landlords.Any())
{
    <p>No landlords found.</p>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Full Name</th>
                <th>Email</th>
                <th>Phone Number</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var landlord in landlords)
            {
                <tr>
                    <td>@landlord.FullName</td>
                    <td>@landlord.Email</td>
                    <td>@landlord.PhoneNumber</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary"
                               href="/landlords/details/@landlord.Id">
                            Details
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Landlord> landlords = new();

    protected override async Task OnInitializedAsync()
    {
        landlords = await Db.Landlords
            .OrderBy(l => l.FullName)
            .ToListAsync();
    }
}