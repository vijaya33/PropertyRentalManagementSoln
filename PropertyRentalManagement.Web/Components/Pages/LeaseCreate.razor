@page "/leases/create"
@using Microsoft.AspNetCore.Components
@using Microsoft.EntityFrameworkCore
@using PropertyRentalManagement.Core.Entities
@inject PropertyRentalManagement.Infrastructure.Data.RentalDbContext Db
@inject NavigationManager Nav

<h3>Add New Lease</h3>

<EditForm Model="Input" OnValidSubmit="SaveAsync" FormName="CreateLeaseForm">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label">Tenant</label>
        <InputSelect TValue="int?" class="form-select" @bind-Value="Input.TenantId">
            <option value="">-- Select Tenant --</option>
            @foreach (var tenant in tenants)
            {
                <option value="@tenant.Id">@tenant.FirstName @tenant.LastName</option>
            }
        </InputSelect>
        <ValidationMessage For="@(() => Input.TenantId)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Property</label>
        <InputSelect TValue="int?" class="form-select" @bind-Value="Input.PropertyId">
            <option value="">-- Select Property --</option>
            @foreach (var property in properties)
            {
                <option value="@property.Id">@property.PropertyName</option>
            }
        </InputSelect>
        <ValidationMessage For="@(() => Input.PropertyId)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Monthly Rent</label>
        <InputNumber class="form-control" @bind-Value="Input.MonthlyRent" />
        <ValidationMessage For="@(() => Input.MonthlyRent)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Security Deposit</label>
        <InputNumber class="form-control" @bind-Value="Input.SecurityDeposit" />
        <ValidationMessage For="@(() => Input.SecurityDeposit)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Lease Start Date</label>
        <InputDate class="form-control" @bind-Value="Input.LeaseStartDate" />
        <ValidationMessage For="@(() => Input.LeaseStartDate)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Lease End Date</label>
        <InputDate class="form-control" @bind-Value="Input.LeaseEndDate" />
        <ValidationMessage For="@(() => Input.LeaseEndDate)" />
    </div>

    <button type="submit" class="btn btn-success">Save</button>
    <a href="/leases" class="btn btn-secondary ms-2">Cancel</a>
</EditForm>

@code {
    [SupplyParameterFromForm]
    private Lease Input { get; set; } = new()
    {
        LeaseStartDate = DateTime.Today,
        LeaseEndDate = DateTime.Today.AddYears(1)
    };

    private List<Tenant> tenants = new();
    private List<Property> properties = new();

    protected override async Task OnInitializedAsync()
    {
        tenants = await Db.Tenants
            .OrderBy(t => t.LastName)
            .ThenBy(t => t.FirstName)
            .ToListAsync();

        properties = await Db.Properties
            .OrderBy(p => p.PropertyName)
            .ToListAsync();
    }

    private async Task SaveAsync()
    {
        if (Input.LeaseEndDate <= Input.LeaseStartDate)
        {
            return;
        }

        var entity = new Lease
        {
            TenantId = Input.TenantId,
            PropertyId = Input.PropertyId,
            MonthlyRent = Input.MonthlyRent,
            SecurityDeposit = Input.SecurityDeposit,
            LeaseStartDate = Input.LeaseStartDate,
            LeaseEndDate = Input.LeaseEndDate
        };

        Db.Leases.Add(entity);
        await Db.SaveChangesAsync();

        Nav.NavigateTo("/leases");
    }
}