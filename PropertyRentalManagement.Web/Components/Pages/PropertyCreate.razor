@page "/properties/create"
@using PropertyRentalManagement.Core.Entities
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components
@using Microsoft.EntityFrameworkCore;
@inject PropertyRentalManagement.Infrastructure.Data.RentalDbContext Db

@inject NavigationManager Nav

<h3>Create Property</h3>

<EditForm Model="Input" OnValidSubmit="SaveAsync" FormName="CreatePropertyForm"> <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label">Property Name</label>
        <InputText class="form-control" @bind-Value="Input.PropertyName" />
    </div>

    <div class="mb-3">
        <label class="form-label">Address Line 1</label>
        <InputText class="form-control" @bind-Value="Input.AddressLine1" />
    </div>

    <div class="mb-3">
        <label class="form-label">Address Line 2</label>
        <InputText class="form-control" @bind-Value="Input.AddressLine2" />
    </div>

    <div class="mb-3">
        <label class="form-label">City</label>
        <InputText class="form-control" @bind-Value="Input.City" />
    </div>

    <div class="mb-3">
        <label class="form-label">State</label>
        <InputText class="form-control" @bind-Value="Input.State" />
    </div>

    <div class="mb-3">
        <label class="form-label">Zip Code</label>
        <InputText class="form-control" @bind-Value="Input.ZipCode" />
    </div>

    <div class="mb-3">
        <label class="form-label">Total Units</label>
        <InputNumber class="form-control" @bind-Value="Input.TotalUnits" />
    </div>

    <div class="mb-3">
        <label class="form-label">Landlord</label>
        <InputSelect class="form-select" @bind-Value="Input.LandlordId">
            <option value="0">-- Select Landlord --</option>
            @foreach (var landlord in landlords)
            {
                <option value="@landlord.Id">@landlord.FullName</option>
            }
        </InputSelect>
    </div>

    <button type="submit" class="btn btn-success">Save</button>
    <a href="/properties" class="btn btn-secondary ms-2">Cancel</a>
</EditForm>

@code {
    [SupplyParameterFromForm]
    private Property Input { get; set; } = new();

    private List<Landlord> landlords = new();

    protected override async Task OnInitializedAsync()
    {
        landlords = await Db.Landlords
            .OrderBy(l => l.FullName)
            .ToListAsync();
    }

    private async Task SaveAsync()
    {
        var entity = new Property
        {
            PropertyName = Input.PropertyName,
            AddressLine1 = Input.AddressLine1,
            AddressLine2 = Input.AddressLine2,
            City = Input.City,
            State = Input.State,
            ZipCode = Input.ZipCode,
            TotalUnits = Input.TotalUnits,
            LandlordId = Input.LandlordId
        };

        Db.Properties.Add(entity);
        await Db.SaveChangesAsync();
        Nav.NavigateTo("/properties");
    }
}