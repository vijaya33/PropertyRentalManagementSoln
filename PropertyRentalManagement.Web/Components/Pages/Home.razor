@page "/"
@layout PropertyRentalManagement.Web.Components.Layout.PublicLayout
@attribute [AllowAnonymous]

<PageTitle>Welcome</PageTitle>
<div class="welcome-wrapper">
    <div class="welcome-header">
        Property Rental Management Platform
    </div>

    <div class="welcome-body">
        <h3>Welcome</h3>

        <p>
            The Property Rental Management Application is a modern web-based platform
            designed to help property management companies manage landlords, rental
            properties, tenants, leases, payments, property photos, and maintenance requests
            from one centralized system.
        </p>

        <p>
            This application provides a secure and organized workflow for managing property
            ownership, rental operations, tenant records, and future SaaS subscription-based
            property management services.
        </p>

        <p>
            Please login to access your dashboard, or register to create a new account.
        </p>

        <div class="welcome-actions">
            <a href="/login" class="btn btn-primary">Login</a>
            <a href="/register" class="btn btn-success">Register</a>
        </div>
    </div>
</div>