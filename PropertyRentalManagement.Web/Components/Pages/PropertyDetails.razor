@page "/properties/details/{id:int}"
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@using PropertyRentalManagement.Core.Entities
@inject PropertyRentalManagement.Infrastructure.Data.RentalDbContext Db
@inject NavigationManager Nav
@rendermode InteractiveServer

<h3>Property Details</h3>

@if (property == null)
{
    <p><em>Loading property details...</em></p>
}
else
{
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <h4>@property.PropertyName</h4>
            <p><strong>Full Address:</strong> @FullAddress</p>
        </div>
    </div>

<div class="card mb-4 shadow-sm">
    <div class="card-body">
        <h5>Upload Property Photo</h5>

        @if (!string.IsNullOrWhiteSpace(uploadMessage))
        {
            <div class="alert alert-info">@uploadMessage</div>
        }

        <InputFile OnChange="HandleFileSelected" accept="image/*" />

        <div class="mt-3">
            <button type="button"
                    class="btn btn-success"
                    @onclick="UploadPhotoAsync"
                    disabled="@(!selectedFileReady || isUploading)">
                @(isUploading ? "Uploading..." : "Upload Photo")
            </button>
        </div>
    </div>
</div>

    <div class="card shadow-sm">
        <div class="card-body">
            <h5>Photos</h5>

            @if (!property.Photos.Any())
            {
                <p>No photos uploaded yet.</p>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var photo in property.Photos)
                    {
                        <div class="col-md-3 col-sm-6">
                            <img src="@GetPhotoUrl(photo.Id)"
                                 alt="@photo.FileName"
                                 class="img-fluid rounded border"
                                 style="height:180px; width:100%; object-fit:cover;" />
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private Property? property;
    private IBrowserFile? selectedFile;
    private bool selectedFileReady;
    private bool isUploading;
    private string? uploadMessage;

    private string FullAddress =>
    property == null
        ? string.Empty
        : string.Join(", ",
            new[]
            {
                property.AddressLine1,
                property.AddressLine2,
                property.City,
                property.State,
                property.ZipCode
            }.Where(x => !string.IsNullOrWhiteSpace(x)));

private string GetPhotoUrl(int photoId) => $"/property-photo/{photoId}";

    protected override async Task OnInitializedAsync()
    {
        await LoadPropertyAsync();
    }

    private async Task LoadPropertyAsync()
    {
        property = await Db.Properties
            .Include(p => p.Landlord)
            .Include(p => p.Photos.OrderBy(ph => ph.UploadedOn))
            .FirstOrDefaultAsync(p => p.Id == Id);
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        selectedFileReady = selectedFile != null;
        uploadMessage = selectedFile != null
            ? $"Selected file: {selectedFile.Name}"
            : "No file selected.";

        await InvokeAsync(StateHasChanged);
    }

    private async Task UploadPhotoAsync()
    {
        if (property == null)
        {
            uploadMessage = "Property was not loaded.";
            return;
        }

        if (selectedFile == null)
        {
            uploadMessage = "Please choose a photo first.";
            return;
        }

        try
        {
            isUploading = true;
            uploadMessage = "Uploading photo...";

            const long maxFileSize = 10 * 1024 * 1024;

            await using var stream = selectedFile.OpenReadStream(maxFileSize);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);

            var photoBytes = memoryStream.ToArray();

            if (photoBytes.Length == 0)
            {
                uploadMessage = "Selected file is empty.";
                return;
            }

            var photo = new PropertyPhoto
            {
                PropertyId = property.Id,
                FileName = selectedFile.Name,
                ContentType = string.IsNullOrWhiteSpace(selectedFile.ContentType)
                    ? "application/octet-stream"
                    : selectedFile.ContentType,
                PhotoData = photoBytes,
                UploadedOn = DateTime.UtcNow
            };

            Db.PropertyPhotos.Add(photo);
            await Db.SaveChangesAsync();

            uploadMessage = "Photo uploaded successfully.";
            selectedFile = null;
            selectedFileReady = false;

            await LoadPropertyAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            uploadMessage = $"Upload failed: {ex.Message}";
        }
        finally
        {
            isUploading = false;
            await InvokeAsync(StateHasChanged);
        }
    }
}