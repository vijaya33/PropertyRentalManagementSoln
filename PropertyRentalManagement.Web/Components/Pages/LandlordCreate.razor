

@page "/landlords/create"
@using PropertyRentalManagement.Core.Entities
@using Microsoft.AspNetCore.Components
@inject PropertyRentalManagement.Infrastructure.Data.RentalDbContext Db
@inject NavigationManager Nav
@attribute [Authorize]


<h3>Add New Landlord</h3>

<EditForm Model="Input" OnValidSubmit="SaveAsync" FormName="CreateLandlordForm">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label">Full Name</label>
        <InputText class="form-control" @bind-Value="Input.FullName" />
    </div>

    <div class="mb-3">
        <label class="form-label">Email</label>
        <InputText class="form-control" @bind-Value="Input.Email" />
    </div>

    <div class="mb-3">
        <label class="form-label">Phone Number</label>
        <InputText class="form-control" @bind-Value="Input.PhoneNumber" />
    </div>

    <button type="submit" class="btn btn-success">Save</button>
    <a href="/landlords" class="btn btn-secondary ms-2">Cancel</a>
</EditForm>

@code {
    [SupplyParameterFromForm]
    private Landlord Input { get; set; } = new();

    private async Task SaveAsync()
    {
        var entity = new Landlord
        {
            FullName = Input.FullName,
            Email = Input.Email,
            PhoneNumber = Input.PhoneNumber
        };

        Db.Landlords.Add(entity);
        await Db.SaveChangesAsync();

        Nav.NavigateTo("/landlords");
    }
}