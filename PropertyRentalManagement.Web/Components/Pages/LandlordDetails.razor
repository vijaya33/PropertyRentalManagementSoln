@page "/landlords/details/{id:int}"
@using Microsoft.EntityFrameworkCore
@using PropertyRentalManagement.Core.Entities
@inject PropertyRentalManagement.Infrastructure.Data.RentalDbContext Db
@inject NavigationManager Nav

@attribute [Authorize]

<h3>Landlord Details</h3>

@if (landlord == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">@landlord.FullName</h5>
            <p class="mb-1"><strong>Email:</strong> @landlord.Email</p>
            <p class="mb-1"><strong>Phone Number:</strong> @landlord.PhoneNumber</p>
            <p class="mb-0"><strong>Total Properties:</strong> @landlord.Properties.Count</p>
        </div>
    </div>

    <h4>Assigned Properties</h4>

    @if (!landlord.Properties.Any())
    {
        <p>No properties assigned to this landlord.</p>
    }
    else
    {
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Property Name</th>
                    <th>City</th>
                    <th>State</th>
                    <th>Total Units</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var property in landlord.Properties)
                {
                    <tr>
                        <td>@property.PropertyName</td>
                        <td>@property.City</td>
                        <td>@property.State</td>
                        <td>@property.TotalUnits</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="mt-3">
        <a href="/landlords" class="btn btn-secondary">Back to Landlords</a>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private Landlord? landlord;

    protected override async Task OnInitializedAsync()
    {
        landlord = await Db.Landlords
            .Include(l => l.Properties)
            .FirstOrDefaultAsync(l => l.Id == Id);
    }
}