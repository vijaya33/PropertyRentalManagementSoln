
@page "/properties"
@inject PropertyRentalManagement.Infrastructure.Data.RentalDbContext Db

@using Microsoft.EntityFrameworkCore;

@using PropertyRentalManagement.Core.Entities

@* @attribute [Authorize] *@



<h3>Properties</h3>

<a class="btn btn-primary mb-3" href="/properties/create">Add Property</a>

@if (!properties.Any())
{
    <p>No properties found.</p>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Name</th>
                <th>City</th>
                <th>State</th>
                <th>Total Units</th>
                <th>Landlord</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in properties)
            {
                <tr>
                    <td>@item.PropertyName</td>
                    <td>@item.City</td>
                    <td>@item.State</td>
                    <td>@item.TotalUnits</td>
                    <td>@item.Landlord?.FullName</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary" href="/properties/details/@item.Id">
                            Details
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Property> properties = new();

    protected override async Task OnInitializedAsync()
    {
        properties = await Db.Properties
            .Include(p => p.Landlord)
            .OrderBy(p => p.PropertyName)
            .ToListAsync();
    }
}